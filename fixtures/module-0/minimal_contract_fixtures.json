    {
      "id": "free_reply_minimal",
      "description": "免费回话最小请求与关键响应字段",
      "request": {
        "endpoint": "POST /reply/analyze",
        "payload": {
          "user_id": "u_free_1",
          "target_id": "t_1",
          "tier": "FREE",
          "text_input": "对方只回了一个 ❤️",
          "user_goal_mode": "MAINTAIN",
          "style_mode": "NATURAL"
        }
      },
      "response_assertions": {
        "required_fields": [
          "contract_version",
          "mode",
          "dashboard",
          "safety",
          "explain_card",
          "reply_session",
          "structured_diagnosis",
          "signals"
        ],
        "expected_mode": "REPLY",
        "expected_reply_route_count": 3
      }
    },
