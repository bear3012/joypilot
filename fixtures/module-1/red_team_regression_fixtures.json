        "endpoint": "POST /upload/prepare",
        "payload": {
          "user_id": "m1-rt-4",
          "target_id": "m1-rt-target-4",
          "tier": "FREE",
          "mode": "RELATIONSHIP",
          "timeline_confirmed": true,
          "my_side": null,
          "screenshots": [
