    {
      "id": "m10_rt4_relationship_empty_screenshots",
      "description": "空截图数组应走可恢复风险提示而非崩溃",
      "request": {
        "endpoint": "POST /upload/prepare",
        "payload": {
          "user_id": "m10-rt4-user-2",
          "target_id": "m10-rt4-target-2",
          "tier": "FREE",
          "mode": "RELATIONSHIP",
          "timeline_confirmed": true,
          "my_side": "LEFT",
          "screenshots": []
        }
      },
      "assertions": {
        "http_status": 200,
        "path_equals": {
          "status": "NEEDS_REVIEW"
        },
        "issue_path": "issues",
        "contains_issue_codes": [
          "NO_SCREENSHOTS"
        ]
      }
    },
    {
      "id": "m10_rt4_reply_mixed_illegal_extra_fields",
      "description": "混入非法额外字段时应忽略并保持主流程可用",
      "request": {
        "endpoint": "POST /reply/analyze",
        "payload": {
          "user_id": "m10-rt4-user-3",
          "target_id": "m10-rt4-target-3",
          "tier": "FREE",
          "text_input": "我们先测试混合非法字段场景。",
          "user_goal_mode": "MAINTAIN",
