{
  "contract_version": "v1.0.0",
  "scenarios": [
    {
      "id": "m10_smoke_health",
      "description": "健康检查最小通过",
      "request": {
        "endpoint": "GET /health"
      },
      "assertions": {
        "http_status": 200,
        "path_equals": {
          "status": "ok",
          "contract_version": "v1.0.0"
        }
      }
    },
    {
      "id": "m10_smoke_api_state",
      "description": "状态快照接口最小可用",
      "request": {
        "endpoint": "GET /api/state"
      },
      "assertions": {
        "http_status": 200,
        "required_fields": [
          "reply_sessions",
          "audit_entries",
          "segment_summaries",
          "entitlement_states",
          "entitlement_pending_locks"
        ]
      }
    },
    {
      "id": "m10_smoke_reply_free_minimal",
      "description": "免费回话最小路径可用",
      "request": {
        "endpoint": "POST /reply/analyze",
        "payload": {
          "user_id": "m10-smoke-user-1",
          "target_id": "m10-smoke-target-1",
          "tier": "FREE",
          "text_input": "对方回了个表情",
          "user_goal_mode": "MAINTAIN",
          "style_mode": "NATURAL"
        }
      },
      "assertions": {
        "http_status": 200,
        "path_equals": {
          "mode": "REPLY",
          "reply_session.active": true
        }
      }
    },
    {
      "id": "m10_smoke_relationship_free_blocked",
      "description": "免费关系判断应被商业门禁拦截",
      "request": {
        "endpoint": "POST /relationship/analyze",
        "payload": {
          "user_id": "m10-smoke-user-2",
          "target_id": "m10-smoke-target-2",
          "tier": "FREE",
          "need_full_report": false,
          "ad_proof_token": null,
          "prepared_upload": {
            "status": "READY",
            "screenshot_count": 2,
            "tier": "FREE",
            "mode": "RELATIONSHIP",
            "timeline_confirmed": true,
            "my_side": "RIGHT",
            "issues": [],
            "ocr_preview": [],
            "dialogue_turns": [
              {
                "speaker": "OTHER",
                "text": "这周有点忙",
                "source_image_id": "img-1"
              },
              {
                "speaker": "SELF",
                "text": "好的你忙完再聊",
                "source_image_id": "img-1"
              }
            ]
          }
        }
      },
      "assertions": {
        "http_status": 200,
        "path_equals": {
          "mode": "RELATIONSHIP",
          "gate_decision": "BLOCK"
        },
        "issue_path": "gating_issues",
        "contains_issue_codes": [
          "ADS_REQUIRED"
        ]
      }
    },
    {
      "id": "m10_smoke_upload_prepare_ready",
      "description": "上传整理最小路径可用",
      "request": {
        "endpoint": "POST /upload/prepare",
        "payload": {
          "user_id": "m10-smoke-user-3",
          "target_id": "m10-smoke-target-3",
          "tier": "FREE",
          "mode": "RELATIONSHIP",
          "timeline_confirmed": true,
          "my_side": "RIGHT",
          "screenshots": [
            {
              "image_id": "img-1",
              "timestamp_hint": "2026-03-28T10:00:00",
              "left_text": "这周有点忙",
              "right_text": "好的，你忙完再说"
            },
            {
              "image_id": "img-2",
              "timestamp_hint": "2026-03-28T10:05:00",
              "left_text": "❤️",
              "right_text": "先不打扰你"
            }
          ]
        }
      },
      "assertions": {
        "http_status": 200,
        "path_equals": {
          "status": "READY"
        },
        "required_fields": [
          "dialogue_turns",
          "ocr_preview"
        ]
      }
    }
  ]
}
